# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# Firebase (Authentication)
# Get these from Firebase Console > Project Settings > General > Your apps
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="MY_MEASUREMENT_ID"

# ---------------------------------------------------------------------------
# Supabase (Database)
# Get these from Supabase Dashboard > Project Settings > API
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL="https://MY_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_PUBLISHABLE_KEY"
